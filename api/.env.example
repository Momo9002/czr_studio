"""
Environment variable config for Aura API.
Copy to .env and fill in your values. Never commit .env to git.
"""

# Required
GOOGLE_API_KEY=your_gemini_api_key_here

# Telnyx (for WhatsApp)
TELNYX_API_KEY=your_telnyx_api_key_here
TELNYX_MESSAGING_PROFILE_ID=your_messaging_profile_id_here

# Momo Telegram notification
MOMO_TELEGRAM_TOKEN=your_telegram_bot_token_here
MOMO_CHAT_ID=your_telegram_chat_id_here
